# Identity webhook service env — copied to identity-webhook/.env at runtime.
#
#   cp identity-webhook/.env.example identity-webhook/.env

# Local dev only — change before any shared or production use.
WEBHOOK_SECRET=dev-webhook-secret-change-me
IDENTITY_ISSUER=http://identity-webhook:8090

# Demo API key resolved by the webhook (must match remote-signer end-user Bearer token).
# DEMO_CLIENT_ID should match the Auth0 public client id (DEMO_APP_AUTH0_PUBLIC_CLIENT_ID).
DEMO_API_KEY=sk_demo_local_key
DEMO_CLIENT_ID=xEJfZBtEP0JLJtlXm9UnJrDrA9bwepLx
DEMO_USER_ID=demo-user
USAGE_SUBJECT_TYPE=api_key_user
# API_KEY_PREFIX=sk_
# DEMO_API_KEYS={"sk_other":{"clientId":"app-b","userId":"user-b"}}

# --- OAuth / OIDC (Auth0 signer JWTs from Builder API exchange) ---
# When both OIDC and API keys are configured, JWTs are tried first, then sk_ keys.
OIDC_ISSUER=https://pymthouse.us.auth0.com/
OIDC_AUDIENCE=livepeer-clearinghouse
# OIDC_JWKS_URI=                       # defaults to ${OIDC_ISSUER}/.well-known/jwks.json
OIDC_CLIENT_CLAIM=app_client_id
OIDC_SUBJECT_CLAIM=external_user_id
# Device-code user tokens lack the custom claims above; verifier falls back to sub / azp.
OIDC_SUBJECT_TYPE=external_user_id
OIDC_REQUIRED_SCOPES=sign:job
