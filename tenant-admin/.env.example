# tenant-admin service env — copied to tenant-admin/.env at runtime.
#
#   cp tenant-admin/.env.example tenant-admin/.env
#   $EDITOR tenant-admin/.env

# --- Admin API ---
# Bearer token required on every /v1 route.
ADMIN_SECRET=dev-tenant-admin-secret-change-me
TENANT_ADMIN_LISTEN_ADDR=:8093
# Internal API. In docker-compose this is overridden to ":8094" so the identity webhook
# can reach it over the private network; it is never published to the host. Bare/host runs
# default to loopback. When set, INTERNAL_API_SECRET is required via the X-Internal-Secret
# header (must match identity-webhook's TENANT_ADMIN_INTERNAL_SECRET).
TENANT_ADMIN_INTERNAL_LISTEN_ADDR=127.0.0.1:8094
# INTERNAL_API_SECRET=dev-internal-secret-change-me
TENANT_ADMIN_DATA_DIR=/app/data

# --- Konnect (required) ---
KONNECT_API_URL=https://global.api.konghq.com
KONNECT_PLATFORM_PAT=
# Role assigned to each tenant's ingest system account (write-only event ingestion).
KONNECT_INGEST_ROLE=Ingest
KONNECT_SPAT_TTL_DAYS=365

# --- OpenMeter (required) ---
OPENMETER_URL=https://us.api.konghq.com/v3/openmeter
# Long-lived "clearinghouse-provisioner" SPAT used for all OpenMeter
# catalog/customer/subscription operations. Held by this service, never returned.
OPENMETER_PROVISIONER_PAT=
OPENMETER_DEFAULT_PLAN_KEY=clearinghouse_default_ppu

# --- Auth0 Management API (required) ---
AUTH0_MGMT_DOMAIN=your-tenant.us.auth0.com
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_DEFAULT_CONNECTION=Username-Password-Authentication
