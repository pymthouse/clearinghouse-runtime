# OpenMeter collector + Builder API service env — copied to openmeter-collector/.env at runtime.
#
#   cp openmeter-collector/.env.example openmeter-collector/.env
#   $EDITOR openmeter-collector/.env

# --- Kafka (event consume) ---
KAFKA_BROKERS=kafka:9092
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events

# --- OpenMeter / Konnect (required) ---
# Konnect: https://<region>.api.konghq.com/v3/openmeter/events
# Self-hosted: https://<host>/api/v1/events
OPENMETER_INGEST_URL=https://us.api.konghq.com/v3/openmeter/events
OPENMETER_URL=https://us.api.konghq.com/v3/openmeter
OPENMETER_API_KEY=
PRICE_ORACLE_URL=https://api.coinbase.com/v2/prices/ETH-USD/spot
PRICE_ORACLE_REFRESH=5m

# --- Builder API (Go, port 8095) ---
# Auth0 tenant + signer M2M are loaded automatically from
# auth0-provisioner/provision/.env.livepeer (mounted at /service/.env.livepeer).
# Only Management API credentials need to be set here (see builder-api/README.md).
BUILDER_API_PORT=8095
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_DB_CONNECTION=Username-Password-Authentication
# Optional overrides (defaults come from .env.livepeer):
# AUTH0_SIGNER_M2M_CLIENT_ID=
# AUTH0_SIGNER_M2M_CLIENT_SECRET=
# AUTH0_AUDIENCE=livepeer-clearinghouse
SIGNER_URL=http://localhost:8081
DISCOVERY_URL=https://discovery-service-production-8955.up.railway.app/v1/discovery/raw?serviceType=legacy
API_KEY_PREFIX=sk_
# Optional demo keys (quote the JSON — shell .env sourcing breaks bare braces)
# DEMO_API_KEYS='{"sk_demo_local_key":{"clientId":"YOUR_PUBLIC_CLIENT_ID","userId":"demo-user"}}'
