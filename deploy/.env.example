# Clearinghouse deploy stack — copy to deploy/.env and fill in values:
#   cp deploy/.env.example deploy/.env
#
# docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d --build

# --- Identity webhook (required by the remote-signer container) ---
# Until the clearinghouse /authorize webhook (issue #2) is implemented, point this at
# whatever -remoteSignerWebhookUrl-compatible identity provider you're using.
# Once issue #2 lands and `pnpm dev` is running, use:
#   REMOTE_SIGNER_WEBHOOK_URL=http://host.docker.internal:8787/authorize
REMOTE_SIGNER_WEBHOOK_URL=http://host.docker.internal:8787/authorize
WEBHOOK_SECRET=replace-with-shared-secret

# --- Remote signer ---
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
SIGNER_ETH_ADDR=
SIGNER_HOST_PORT=8081

# --- Kafka ---
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events

# --- OpenMeter / Konnect Metering & Billing ---
# Regional base URLs:
#   US: https://us.api.konghq.com/v3/openmeter
#   EU: https://eu.api.konghq.com/v3/openmeter
#   AU: https://au.api.konghq.com/v3/openmeter
#   SG: https://sg.api.konghq.com/v3/openmeter
# OPENMETER_INGEST_URL must be set explicitly (no nested interpolation in compose).
OPENMETER_URL=https://us.api.konghq.com/v3/openmeter
OPENMETER_INGEST_URL=https://us.api.konghq.com/v3/openmeter/events
OPENMETER_API_KEY=kpat_your_konnect_personal_access_token

# For self-hosted OpenMeter, set OPENMETER_INGEST_URL to:
#   OPENMETER_INGEST_URL=https://your-openmeter-host/api/v1/events

# --- ETH/USD price for fee conversion (USD micros) ---
ETH_USD_PRICE=3500
