# Runtime stack env for deploy/docker-compose.yml
#
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d --build

# --- Identity webhook (required) ---
WEBHOOK_SECRET=dev-webhook-secret-change-me
REMOTE_SIGNER_WEBHOOK_URL=http://identity-webhook:8090/authorize
IDENTITY_ISSUER=http://identity-webhook:8090

# --- Billing gateway (balance gate on /authorize) ---
BILLING_GATEWAY_URL=http://billing-gateway:8092
# BILLING_GATEWAY_SECRET defaults to WEBHOOK_SECRET in compose
BALANCE_CHECK_ENABLED=1
OPENMETER_BALANCE_FEATURE_KEY=billable_spend

# --- OpenMeter / Konnect (required for billing-gateway + collector) ---
OPENMETER_URL=https://us.api.konghq.com/v3/openmeter
OPENMETER_INGEST_URL=https://us.api.konghq.com/v3/openmeter/events
OPENMETER_API_KEY=
OPENMETER_DEFAULT_PLAN_KEY=clearinghouse_default_ppu

# --- Demo API key (resolved by identity-webhook) ---
DEMO_API_KEY=sk_demo_local_key
DEMO_CLIENT_ID=demo-client
DEMO_USER_ID=demo-user
USAGE_SUBJECT_TYPE=api_key_user
# DEMO_API_KEYS={"sk_other":{"clientId":"app-b","userId":"user-b"}}

# --- Signer ---
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
SIGNER_ETH_ADDR=
SIGNER_HOST_PORT=8081
SIGNER_REMOTE_DISCOVERY=0
# ORCH_WEBHOOK_URL=
# LIVE_AI_CAP_REPORT_INTERVAL=

# --- Kafka ---
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events

# --- Collector ---
ETH_USD_PRICE=3500

# Kafka + signer only (no Konnect): set BALANCE_CHECK_ENABLED=0
