# Runtime stack env for deploy/docker-compose.yml
#
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d --build

# --- Identity webhook (required) ---
WEBHOOK_SECRET=dev-webhook-secret-change-me
REMOTE_SIGNER_WEBHOOK_URL=http://identity-webhook:8090/authorize
IDENTITY_ISSUER=http://identity-webhook:8090

# --- Demo API key (resolved by identity-webhook) ---
DEMO_API_KEY=sk_demo_local_key
DEMO_TENANT_ID=demo
DEMO_CLIENT_ID=demo-client
DEMO_USER_ID=demo-user
USAGE_SUBJECT_TYPE=api_key_user
# DEMO_API_KEYS={"sk_other":{"tenantId":"acme","clientId":"app-b","userId":"user-b"}}

# --- Usage reads (identity-webhook /usage/me when enabled) ---
USAGE_QUERY_ENABLED=0
# USAGE_QUERY_ENABLED=1
# OPENMETER_TRIAL_FEATURE_KEY=network_spend
# JWT_ISSUER=
# JWT_AUDIENCE=
# ALLOW_INSECURE_HTTP=0

# --- Signer ---
SIGNER_NETWORK=arbitrum-one-mainnet
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
SIGNER_ETH_ADDR=
SIGNER_HOST_PORT=8081
SIGNER_REMOTE_DISCOVERY=0
# ORCH_WEBHOOK_URL=
# LIVE_AI_CAP_REPORT_INTERVAL=

# --- Kafka ---
KAFKA_GATEWAY_TOPIC=livepeer-gateway-events

# --- OpenMeter / Konnect (collector + optional identity-webhook usage reads) ---
OPENMETER_URL=https://us.api.konghq.com/v3/openmeter
OPENMETER_INGEST_URL=https://us.api.konghq.com/v3/openmeter/events
OPENMETER_API_KEY=
OPENMETER_DEFAULT_PLAN_KEY=clearinghouse_default_ppu
ETH_USD_PRICE=3500
# DEFAULT_TENANT_ID=demo

# --- tenant-admin (per-tenant Auth0 + Konnect provisioning) ---
ADMIN_SECRET=dev-tenant-admin-secret-change-me
TENANT_ADMIN_LISTEN_ADDR=:8093
TENANT_ADMIN_DATA_DIR=/app/data
KONNECT_API_URL=https://global.api.konghq.com
KONNECT_PLATFORM_PAT=
# Ingest role name to assign for tenant SPATs.
# tenant-admin also assigns Meter Admin, Product Catalog Admin, and Billing Admin.
KONNECT_INGEST_ROLE=Ingest
KONNECT_SPAT_TTL_DAYS=365
AUTH0_MGMT_DOMAIN=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_DEFAULT_CONNECTION=Username-Password-Authentication
