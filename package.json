{
  "name": "clearinghouse",
  "version": "0.1.0",
  "private": true,
  "description": "Official Livepeer example: remote-signer auth + usage metering on @pymthouse/builder-sdk",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build:packages": "pnpm --filter @pymthouse/konnect-metering build",
    "build": "pnpm run build:packages && tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "pnpm run build:packages && tsc",
    "lint": "eslint .",
    "test": "pnpm run build:packages && vitest run",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "openmeter:bootstrap": "tsx --env-file=.env scripts/openmeter-bootstrap.ts",
    "provision:customer": "tsx --env-file=.env scripts/provision-customer.ts"
  },
  "dependencies": {
    "@openmeter/sdk": "^1.0.0-beta.228",
    "@pymthouse/builder-sdk": "^0.4.1",
    "@pymthouse/konnect-metering": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/livepeer/clearinghouse.git"
  },
  "bugs": {
    "url": "https://github.com/livepeer/clearinghouse/issues"
  },
  "homepage": "https://github.com/livepeer/clearinghouse#readme"
}
